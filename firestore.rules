rules_version = '2';
// Beemo — güvenlik kuralları.
// Mantık: herkes profilleri okuyabilir (arkadaş eklemek için), ama
// - kendi profilini yazabilir
// - başkasının requests/friends/inbox koleksiyonuna SADECE kendini temsil eden doc yazabilir
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Profilleri giriş yapan herkes okuyabilir (arama + public key için)
      allow read: if signedIn();
      // Profilini yalnızca sahibi yazar
      allow write: if isMe(uid);

      // Gelen arkadaşlık istekleri
      match /requests/{fromUid} {
        allow read, delete: if isMe(uid);              // sahibi yönetir
        allow create: if isMe(fromUid)                 // sadece kendini gönderebilirsin
                      && request.resource.data.fromUid == request.auth.uid;
      }

      // Arkadaş listesi
      match /friends/{friendUid} {
        allow read, delete: if isMe(uid);              // sahibi okur/siler
        allow create, update: if isMe(uid)             // kendi listene ekleyebilirsin
                      || (isMe(friendUid)              // ya da karşıya kendini ekleyebilirsin
                          && request.resource.data.uid == request.auth.uid);
      }

      // Gelen kutusu
      match /inbox/{msgId} {
        allow read, update, delete: if isMe(uid);      // sahibi okur/işaretler/siler
        allow create: if signedIn()                    // herkes mesaj yollayabilir
                      && request.resource.data.from == request.auth.uid;
      }
    }

    // Davetler: kod bir "yetenek" gibi davranır (kodu bilen kabul edebilir)
    match /invites/{code} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.from == request.auth.uid;
      allow update: if signedIn() && request.resource.data.redeemedBy == request.auth.uid;
    }

    // Abonelik durumu — yalnızca sunucu (Cloud Function / Admin) yazar.
    // Kullanıcı sadece OKUR → Pro'yu sahteleyemez.
    match /billing/{uid} {
      allow read: if isMe(uid);
      allow write: if false;
    }
  }
}
